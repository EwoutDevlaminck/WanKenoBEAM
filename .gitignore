# Byte-compiled / cache files
__pycache__/
*.py[cod]

# Virtual environment
venv/
*.egg-info/

# Jupyter checkpoints
.ipynb_checkpoints/

# Cython-generated C files (regenerated from .pyx by gmake)
*.c

# Compiled extensions, libraries, object files (regenerated by gmake)
*.so
*.o
*.a

# Build directory
build/

# Shell scripts
*.sh
